# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/job-tracker

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Instructions:
# 1. Copy this file to .env
# 2. Replace the MONGO_URI with your actual MongoDB connection string
# 3. For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/job-tracker
# 4. For local MongoDB: mongodb://localhost:27017/job-tracker